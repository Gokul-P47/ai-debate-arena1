GROK_API_KEY=
GROK_MODEL=grok-3
GROK_BASE_URL=https://api.x.ai/v1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Which provider to use for debates: openai | grok | gemini
LLM_PROVIDER=openai

# Memory / context tuning
SUMMARY_INTERVAL_TURNS=2
RECENT_MESSAGE_LIMIT=4

# Which TTS provider to use: elevenlabs | openai
TTS_PROVIDER=elevenlabs
TTS_ENABLED=true

# ElevenLabs TTS Settings (optional — leave blank to skip audio)
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL=eleven_flash_v2_5
